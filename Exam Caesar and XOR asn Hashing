1)Caesar Decrypt
def solution(k: int, text: str) -> str:
    s = ""

    for c in text:
        if 'a' <= c <= 'z':
            s += chr(ord('a') + (ord(c) - ord('a') - k) % 26)
        elif 'A' <= c <= 'Z':
            s += chr(ord('A') + (ord(c) - ord('A') - k) % 26)
        else:
            s += c

    return s


