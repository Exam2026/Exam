12)Recover XOR Key from Known Prefix
def solution(hex_ct: str, prefix: str) -> str:
    ct = bytes.fromhex(hex_ct)
    pref = prefix.encode()
    return bytes(ct[i] ^ pref[i] for i in range(len(pref))).decode()
