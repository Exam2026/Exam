 3)Caesar Brute Force with Crib
 def solution(ct: str, crib: str) -> str:
    for k in range(26):
        s = ""
        for c in ct:
            if 'a' <= c <= 'z':
                s += chr((ord(c)-97-k)%26+97)
            elif 'A' <= c <= 'Z':
                s += chr((ord(c)-65-k)%26+65)
            else:
                s += c

        if crib.lower() in s.lower():
            return s

    return ""


